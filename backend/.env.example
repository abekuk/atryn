# Set MOCK_AI=true to stub Bedrock calls locally
MOCK_AI=true

# Set USE_DYNAMO=true to read from DynamoDB instead of seed JSON
USE_DYNAMO=false

# AWS Region
AWS_REGION=us-west-2

# DynamoDB table name
DYNAMO_TABLE=CampusResources

# Bedrock model ID (uses Converse API)
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6
